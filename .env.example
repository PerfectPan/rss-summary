# GitHub Home exact mode is the default.
# Run `rss-summary github-home login` once to create this storage state.
GITHUB_FEED_SOURCE=home
GITHUB_HOME_STORAGE_STATE=.state/github-home-storage.json
# GITHUB_HOME_BROWSER_CHANNEL=chrome

# Optional: used for GitHub API enrichment and for GITHUB_FEED_SOURCE=events fallback.
GH_FEED_TOKEN=

# Defaults to PerfectPan.
GITHUB_USERNAME=PerfectPan

# Optional generic webhook endpoint. If omitted, the digest prints to stdout only.
NOTIFY_WEBHOOK_URL=

# Optional tuning.
FEED_EVENT_PAGES=3
FEED_PER_PAGE=100
FEED_WINDOW_HOURS=36
FEED_MAX_REPOS=30
FEED_INTERESTS=agent,coding-agent,llm,mcp,ai,rust,typescript,javascript,toolchain,bundler,vite,deno,testing,performance,skills
FEED_STATE_FILE=.state/feed-state.json
# FEED_ONLY_NEW=true
# FEED_OUTPUT_FORMAT=json

# Optional RSS/Atom feeds. Prefer RSS_FEEDS_FILE for local machine setup.
# RSS_FEEDS='[{"name":"Deno Blog","url":"https://deno.com/feed","tags":["deno","runtime"]}]'
RSS_FEEDS_FILE=feeds.json
